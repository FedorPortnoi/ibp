# IBP Prototypes Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values
# cp .env.template .env

# ============================================
# VK API Configuration
# ============================================
# Get from: https://dev.vk.com/

# Service token (for search, public profiles)
VK_SERVICE_TOKEN=

# User token (for friends, posts, photos)
# Requires OAuth authorization
VK_USER_TOKEN=

# Combined token (use service or user based on need)
VK_API_TOKEN=${VK_SERVICE_TOKEN}

# API version (recommended: 5.131)
VK_API_VERSION=5.131

# Rate limiting (requests per second)
VK_RPS_LIMIT=3

# ============================================
# Telegram API Configuration
# ============================================
# Get from: https://my.telegram.org/

TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Session name (creates .session file)
TELEGRAM_SESSION_NAME=ibp_telegram

# ============================================
# Database Configuration
# ============================================

# SQLite (development)
DATABASE_URL=sqlite:///investigation.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/ibp_db

# ============================================
# Face Recognition Configuration
# ============================================

# Backend: face_recognition, deepface, opencv
FACE_BACKEND=face_recognition

# Detection model: hog (fast), cnn (accurate)
FACE_DETECTION_MODEL=hog

# Match threshold (lower = stricter)
FACE_MATCH_THRESHOLD=0.6

# ============================================
# Scraping Configuration
# ============================================

# Minimum delay between requests (seconds)
SCRAPE_MIN_DELAY=1.0

# Maximum delay between requests (seconds)
SCRAPE_MAX_DELAY=3.0

# Request timeout (seconds)
SCRAPE_TIMEOUT=30

# ============================================
# Proxy Configuration (Optional)
# ============================================

# HTTP proxy
# HTTP_PROXY=http://user:pass@proxy:8080

# HTTPS proxy
# HTTPS_PROXY=http://user:pass@proxy:8080

# Proxy list file (one per line)
# PROXY_LIST_FILE=proxies.txt

# ============================================
# OK.ru Configuration (Optional)
# ============================================

# Session cookies (export from browser)
# Format: name1=value1; name2=value2
OK_SESSION_COOKIES=

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file (empty = console only)
LOG_FILE=

# ============================================
# NLP Configuration
# ============================================

# Path to Dostoevsky model
DOSTOEVSKY_MODEL_PATH=

# Enable Russian NLP features
ENABLE_RUSSIAN_NLP=true

# ============================================
# Export Configuration
# ============================================

# Default output directory
OUTPUT_DIR=./output

# PDF generation (requires weasyprint)
ENABLE_PDF_EXPORT=false

# ============================================
# Demo Mode
# ============================================

# Force demo mode (no real API calls)
DEMO_MODE=false
