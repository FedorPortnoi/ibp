# ============================================
# IBP Production Environment Variables
# Copy to .env and fill in values
# ============================================

# === REQUIRED ===
FLASK_ENV=production
SECRET_KEY=                         # Flask session secret (generate: python -c "import secrets; print(secrets.token_hex(32))")

# === APP AUTH ===
IBP_PASSWORD=                       # App login password (unset = no auth)
# IBP_PASSWORD_HASH=                # bcrypt hash alternative (takes precedence over IBP_PASSWORD)
# IBP_SESSION_TIMEOUT=3600          # Session timeout in seconds
# IBP_SESSION_REMEMBER=2592000      # "Remember me" timeout in seconds

# === VK API (dual-token) ===
VK_SERVICE_TOKEN=                   # Permanent app token for search (users.search, users.get)
VK_APP_ID=                          # VK app ID for OAuth
# VK_USER_TOKEN=                    # User OAuth token for private data (wall.get, friends.get). Get via: python scripts/auth_vk.py
# VK_TOKEN=                         # Legacy fallback (treated as user token if VK_USER_TOKEN unset)

# === TELEGRAM ===
TELEGRAM_API_ID=                    # From my.telegram.org/apps
TELEGRAM_API_HASH=
TELEGRAM_PHONE=                     # Phone number with country code

# === OK.RU ===
# OK_SESSION_TOKEN=                 # OK.ru session cookie (demo mode if unset)

# === PAID BREACH APIs (return empty without keys) ===
# SNUSBASE_API_KEY=                 # $5-16/mo
# DEHASHED_EMAIL=                   # $5.49/mo (both email + key needed)
# DEHASHED_API_KEY=
# LEAKCHECK_API_KEY=                # Free public tier if unset
# HIBP_API_KEY=                     # $3.50/mo (free k-anonymity if unset)

# === PHONE LOOKUP (return empty without keys) ===
# GETCONTACT_API_KEY=
# NUMBUSTER_API_KEY=

# === FACE SEARCH ===
# SEARCH4FACES_API_KEY=             # $40+/mo (Playwright free fallback if unset)

# === EMAIL APIs ===
# HUNTER_API_KEY=                   # Free tier: 25/month

# === GOVERNMENT SERVICES ===
# FSSP_API_TOKEN=                   # FSSP enforcement API (Russian IP required)
# ENABLE_GEO_RESTRICTED_CHECKERS=1  # Enable Gosuslugi + Sberbank (Russian IP only)

# === LOCAL DATA ===
# LEAKDB_DATA_DIR=                  # Default: data/demo/
# DATABASE_URL=                     # Default: sqlite:///ibp.db

# === OSINT TOOLS ===
# OSINT_TOOLS_DIR=                  # Path to snoop/maigret/sherlock. Default: ~/osint_tools
