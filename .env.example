# ===========================================
# IBP Configuration — Copy to .env and fill in
# ===========================================

# --- Required ---
SECRET_KEY=generate-a-random-secret-key-here
# Flask secret for sessions. Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# --- Flask ---
FLASK_ENV=development
# Options: development, production, testing

DATABASE_URL=sqlite:///ibp.db
# Default SQLite. For PostgreSQL: postgresql://user:pass@host/dbname

# --- Authentication (optional — app runs without auth if unset) ---
IBP_PASSWORD=
# Plain-text password for login. Set either this or IBP_PASSWORD_HASH.
IBP_PASSWORD_HASH=
# bcrypt hash of password. Takes precedence over IBP_PASSWORD.
IBP_SESSION_TIMEOUT=3600
# Session timeout in seconds (default: 1 hour)
IBP_SESSION_REMEMBER=2592000
# "Remember me" timeout in seconds (default: 30 days)

# --- VK API ---
VK_SERVICE_TOKEN=
# Get from: https://vk.com/apps?act=manage -> create app -> service token
VK_TOKEN=
# VK user token (expires 24h). Alternative to service token.
VK_APP_ID=
VK_API_VERSION=5.199

# --- VK Web Login (optional, for web search fallback) ---
VK_LOGIN=
VK_LOGIN_EMAIL=
VK_PASSWORD=

# --- Telegram (optional) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
# Get from: https://my.telegram.org/apps

# --- FSSP / Enforcement Records (optional) ---
FSSP_API_TOKEN=
# Get from: https://api-ip.fssp.gov.ru/ (requires Russian IP)

# --- Email Verification APIs (optional) ---
HUNTER_API_KEY=
# Get from: https://hunter.io/api-keys (free tier: 25/month)
EMAILREP_API_KEY=
# Get from: https://emailrep.io/

# --- Email Finder APIs (optional) ---
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
# Get from: https://snov.io/

# --- Breach / Leak Database APIs ---

# Snusbase — email/username breach search ($5-16/mo)
# https://docs.snusbase.com/
SNUSBASE_API_KEY=

# DeHashed — name/email/phone breach records ($5.49/mo)
# https://www.dehashed.com/
DEHASHED_EMAIL=
DEHASHED_API_KEY=

# LeakCheck Pro — full breach results ($2.99-24.99/mo)
# Without key, free public tier is used automatically.
# https://leakcheck.io/api
LEAKCHECK_API_KEY=

# HIBP (Have I Been Pwned) — email breach history
# Free: password k-anonymity (no key needed)
# Paid ($3.50/mo): email breach lookup, removes rate limits
# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# --- Phone Lookup APIs ---

# GetContact — phone-to-name reverse lookup
# Simple API key mode (paid API service):
GETCONTACT_API_KEY=
# Legacy mode (requires rooted Android device):
# GETCONTACT_TOKEN=
# GETCONTACT_AES_KEY=
# GETCONTACT_DEVICE_ID=

NUMBUSTER_API_KEY=
HIMERA_API_KEY=

# --- Facial Recognition (optional) ---
SEARCH4FACES_API_KEY=
# Search4Faces API key (usually works without key for basic searches)

# --- Local Leak Database ---
# Directory for demo/imported leak CSV files.
# Default: data/demo/ (ships with small fake datasets for testing)
LEAKDB_DATA_DIR=

# --- OK.ru (optional) ---
OK_SESSION_TOKEN=
# OK.ru session cookie. Demo mode (3 fake profiles) if unset.

# --- OSINT Tools Directory ---
OSINT_TOOLS_DIR=
# Path to OSINT tools (snoop, maigret, sherlock). Default: ~/osint_tools
# In Docker, maigret/sherlock are pip-installed; Snoop is not bundled.

# --- Geo-Restricted Services ---
ENABLE_GEO_RESTRICTED_CHECKERS=
# Set to "1" or "true" for Russian IP deployments.
# Enables Gosuslugi and Sberbank forgot-password checkers.

# --- AI Integration (optional) ---
ANTHROPIC_API_KEY=
# Claude API key for AI-powered summaries (risk narrative, behavioral profile, executive summary, court interpretation)
# Get from: https://console.anthropic.com/settings/keys

# --- Other APIs (optional) ---
GITHUB_TOKEN=
# GitHub personal access token for profile lookups
INFOTRACKPEOPLE_API_KEY=
