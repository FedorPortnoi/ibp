# VK API (get service token from https://vk.com/apps?act=manage -> your app -> Settings -> Service access key)
# Service tokens never expire — no refresh needed
VK_SERVICE_TOKEN=your_service_token_here
VK_APP_ID=your_app_id_here

# VK auto-login for Playwright web scraping (optional — improves search results)
# Phone number or email used to log in to VK
VK_LOGIN=+1234567890
VK_LOGIN_EMAIL=your_email@example.com
VK_PASSWORD=your_vk_password

# Optional - Phase 2 services
SEARCH4FACES_API_KEY=
